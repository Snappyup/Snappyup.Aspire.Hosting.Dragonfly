<Project>
  <PropertyGroup>
    <AspNetCoreHealthChecksRedisPackageVersion>8.0.1</AspNetCoreHealthChecksRedisPackageVersion>
    <AspireHostingPackageVersion>9.5.0</AspireHostingPackageVersion>
    <MicrosoftSourceLinkGitHubPackageVersion>8.0.0</MicrosoftSourceLinkGitHubPackageVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageVersion Include="Aspire.Hosting" Version="$(AspireHostingPackageVersion)" />
    <PackageVersion Include="AspNetCore.HealthChecks.Redis" Version="$(AspNetCoreHealthChecksRedisPackageVersion)" />
    <PackageVersion Include="Microsoft.SourceLink.GitHub" Version="$(MicrosoftSourceLinkGitHubPackageVersion)" />
  </ItemGroup>

</Project>
